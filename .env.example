# Copy to .env.local for local development
AUTH_SECRET=dev-secret-change-in-production-min-32-chars
AUTH_DEV_MODE=true
# Neon Postgres connection string (from Vercel → Settings → Environment Variables)
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require
NEXT_PUBLIC_CONTACT_EMAIL=ieee@andrew.cmu.edu
ALLOWED_EMAIL_DOMAINS=andrew.cmu.edu,cmu.edu

